/* pages/detail/detail.wxss */

/* 自定义导航栏 */
.detail-navbar {
  width: 100%;
  height: 90rpx;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 100;
  background-color: var(--background-color);
  border-bottom: 2rpx solid var(--border-color);
  padding: 0 20rpx;
}

.navbar-title {
  font-size: 32rpx;
  font-weight: 500;
}

.back-btn, .action-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 容器样式 */
.container {
  padding: 30rpx;
  background-color: #1a1a1a;
  min-height: 100vh;
  position: relative;
  padding-bottom: 150rpx;
  color: #ffffff;
  padding-top: 80rpx;
}

/* 标题区域 */
.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title-section {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.main-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #ffffff;
  text-align: center;
}

.sub-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.4;
  text-align: center;
  max-width: 90%;
}

/* 概览卡片 */
.overview-card {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* 价格和收藏按钮并排显示 */
.price-favorite-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

/* 价格区域 */
.price-section {
  flex: 1;
}

.price-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 10rpx;
}

.price-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b00;
}

/* 收藏按钮样式 */
.favorite-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 15rpx 25rpx;
  margin-left: 20rpx;
}

.favorite-btn.active {
  background-color: rgba(255, 107, 0, 0.2);
  border-color: rgba(255, 107, 0, 0.5);
}

.favorite-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.favorite-text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 分享按钮样式 */
.share-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 15rpx 25rpx;
  margin-left: 20rpx;
}

.share-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.share-text {
  font-size: 24rpx;
  color: #ffffff;
}

/* 编辑按钮 */
.edit-btn {
  margin-top: 10rpx;
  background-color: #ff6b00;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 10rpx;
  font-weight: bold;
}

.btn-text {
  color: white;
  font-size: 30rpx;
}

/* 配件清单 */
.parts-list {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.1);
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 30rpx;
  padding-bottom: 15rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.component-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.component-item:last-child {
  border-bottom: none;
}

.component-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 107, 0, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 36rpx;
}

.component-details {
  flex: 1;
}

.component-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
}

.component-spec {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.4;
}

.component-price {
  font-size: 28rpx;
  color: #ff6b00;
  font-weight: bold;
}

/* 配置描述 */
.description-section {
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.1);
  margin-bottom: 40rpx;
}

.description-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 20rpx;
}

/* 创建信息 */
.creation-info {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx;
  background-color: rgba(26, 26, 26, 0.9);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: space-between;
  z-index: 10;
  box-sizing: border-box;
}

.bottom-btn {
  flex: 1;
  padding: 20rpx 30rpx;
  text-align: center;
  border-radius: 10rpx;
  font-weight: bold;
  font-size: 28rpx;
  margin: 0 10rpx;
  border: none;
}

.bottom-btn.primary {
  background-color: #ff6b00;
  color: white;
}

.bottom-btn.share {
  background-color: rgba(255, 255, 255, 0.15);
  color: white;
}

/* 错误容器 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100rpx;
}

.error-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.error-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 40rpx;
}

.return-btn {
  background-color: #ff6b00;
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255, 140, 0, 0.2);
  border-top: 6rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 分享面板样式 */
.share-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: flex-end;
}

.share-panel {
  width: 100%;
  background-color: #222222;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 30rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.share-panel-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #ffffff;
}

.share-options {
  display: flex;
  justify-content: space-around;
  margin-bottom: 50rpx;
}

.share-option {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-option-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.share-option-name {
  font-size: 26rpx;
  color: #ffffff;
}

.share-panel-close {
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  margin-top: 20rpx;
}

/* 懒加载相关样式 */
.components-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.components-loading .loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.components-loading .loading-text {
  font-size: 28rpx;
  color: #666;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
} 