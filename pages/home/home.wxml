<!--pages/home/home.wxml-->
<view class="container">
  <!-- 页面头部 -->
  <view class="header flex-row justify-between align-center">
    <view class="page-title">台式电脑配置助手</view>
    <view class="search-box" bindtap="navToSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索配置方案</text>
    </view>
  </view>

  <!-- 欢迎卡片 -->
  <view class="welcome-card">
    <view class="welcome-text">
      <view class="welcome-title">欢迎使用配置助手</view>
      <view class="welcome-subtitle">专业定制，轻松组装您的理想电脑</view>
    </view>
    <view class="welcome-icon">
      <image src="/static/images/categories/icon-work.png" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" circular="{{true}}">
    <swiper-item>
      <image src="cloud://your-cloud-env-id.7063-your-cloud-env-id-1349103669/static/images/banners/Banner1.png" mode="aspectFill"></image>
    </swiper-item>
    <swiper-item>
      <image src="cloud://your-cloud-env-id.7063-your-cloud-env-id-1349103669/static/images/banners/Banner2.png" mode="aspectFill"></image>
    </swiper-item>
    <swiper-item>
      <image src="cloud://your-cloud-env-id.7063-your-cloud-env-id-1349103669/static/images/banners/Banner3.png" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <!-- 快速操作 - 卡片式横向滑动 -->
  <view class="section-title-container">
    <text class="section-title">快速操作</text>
    <text class="section-subtitle">滑动查看更多功能</text>
  </view>
  
  <scroll-view class="action-cards" scroll-x="true" enable-flex="true" enhanced="true" show-scrollbar="false">
    <view class="action-card" bindtap="navToConfig">
      <view class="action-card-icon">
        <view class="icon-bg config-bg">
          <text class="iconfont icon-config"></text>
        </view>
      </view>
      <view class="action-card-content">
        <view class="action-card-title">配置生成</view>
        <view class="action-card-desc">根据需求定制电脑配置</view>
      </view>
    </view>
    
    <view class="action-card" bindtap="navToPlans">
      <view class="action-card-icon">
        <view class="icon-bg plans-bg">
          <text class="iconfont icon-plans"></text>
        </view>
      </view>
      <view class="action-card-content">
        <view class="action-card-title">方案浏览</view>
        <view class="action-card-desc">查看热门电脑配置方案</view>
      </view>
    </view>
    
    <view class="action-card" bindtap="navToComparison">
      <view class="action-card-icon">
        <view class="icon-bg compare-bg">
          <text class="iconfont icon-compare"></text>
        </view>
      </view>
      <view class="action-card-content">
        <view class="action-card-title">配置对比</view>
        <view class="action-card-desc">比较不同方案优劣</view>
      </view>
    </view>
    
    <view class="action-card" bindtap="navToPreference">
      <view class="action-card-icon">
        <view class="icon-bg preference-bg">
          <text class="iconfont icon-preference"></text>
        </view>
      </view>
      <view class="action-card-content">
        <view class="action-card-title">智能推荐</view>
        <view class="action-card-desc">基于偏好智能推荐配置</view>
      </view>
    </view>
  </scroll-view>

  <!-- 立即定制按钮 - 悬浮设计 -->
  <view class="floating-btn-container">
    <button class="floating-btn" hover-class="btn-hover" bindtap="navToConfig">
      <text class="btn-text">立即定制我的电脑</text>
    </button>
  </view>
</view> 