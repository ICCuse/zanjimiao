/* pages/home/home.wxss */

.container {
  padding: 0 0 120rpx 0; /* 增加底部padding，为悬浮按钮留出空间 */
  box-sizing: border-box;
  background-color: var(--background-color);
}

/* 页面头部 */
.header {
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  width: 320rpx;
}

.search-icon {
  margin-right: 10rpx;
}

.search-placeholder {
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* 欢迎卡片样式 */
.welcome-card {
  margin: 20rpx 30rpx 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #FF9500, #FF5E3A);
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(255, 94, 58, 0.2);
}

.welcome-text {
  flex: 1;
}

.welcome-title {
  font-size: 38rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.welcome-icon {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.welcome-icon image {
  width: 100rpx;
  height: 100rpx;
}

/* 轮播图样式 */
.banner {
  width: 100%;
  height: 300rpx;
  margin-bottom: 30rpx;
}

.banner image {
  width: 100%;
  height: 100%;
  border-radius: 0;
}

/* 快速操作区域标题 */
.section-title-container {
  padding: 0 30rpx;
  margin: 20rpx 0;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 卡片式横向滑动 */
.action-cards {
  width: 100%;
  white-space: nowrap;
  padding: 20rpx 0 30rpx 20rpx;
}

.action-card {
  display: inline-flex;
  flex-direction: column;
  width: 450rpx;
  height: 200rpx;
  background-color: var(--surface-color);
  border-radius: 16rpx;
  margin-right: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.action-card-icon {
  margin-bottom: 20rpx;
}

.icon-bg {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  font-size: 32rpx;
}

.config-bg {
  background: linear-gradient(135deg, #36D1DC, #5B86E5);
}

.plans-bg {
  background: linear-gradient(135deg, #FF9500, #FF5E3A);
}

.compare-bg {
  background: linear-gradient(135deg, #834D9B, #D04ED6);
}

.preference-bg {
  background: linear-gradient(135deg, #11998E, #38EF7D);
}

.action-card-content {
  display: flex;
  flex-direction: column;
  white-space: normal;
}

.action-card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.action-card-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* 使用图标字体 (假设你已有iconfont或使用emoji替代) */
.iconfont {
  font-family: "iconfont" !important;
  font-style: normal;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.icon-config:before {
  content: "📝";
}

.icon-plans:before {
  content: "📋";
}

.icon-compare:before {
  content: "⚖️";
}

.icon-preference:before {
  content: "✨";
}

/* 悬浮按钮 */
.floating-btn-container {
  position: fixed;
  bottom: 30rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 0 30rpx;
  z-index: 100;
}

.floating-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #FF9500, #FF5E3A);
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(255, 94, 58, 0.4);
  border: none;
  transition: all 0.3s ease;
  letter-spacing: 2rpx;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
}

.btn-text {
  padding: 0 10rpx;
  color: #ffffff;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-hover {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 25rpx rgba(255, 94, 58, 0.5);
}

/* Flex 工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.justify-between {
  justify-content: space-between;
}

.align-center {
  align-items: center;
} 