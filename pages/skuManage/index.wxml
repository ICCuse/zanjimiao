<view class="container">
  <view class="price-update-panel">
    <view class="update-title">价格更新策略</view>
    <view class="update-strategy">
      <view class="strategy-item {{priceStrategy === 'jdApi' ? 'active' : ''}}" bindtap="selectStrategy" data-strategy="jdApi">
        <view class="strategy-name">京东API更新</view>
        <view class="strategy-desc">根据京东商城价格自动更新</view>
      </view>
      <view class="strategy-item {{priceStrategy === 'supplier' ? 'active' : ''}}" bindtap="selectStrategy" data-strategy="supplier">
        <view class="strategy-name">供应商价格</view>
        <view class="strategy-desc">基于供应商价格计算</view>
      </view>
    </view>
    <button class="update-btn" bindtap="updatePrice">更新价格</button>
  </view>

  <view class="button-group">
    <button class="create-test-btn" bindtap="createTestData">创建测试数据</button>
  </view>

  <view class="debug-panel">
    <button class="debug-btn" bindtap="testCloudEnv">测试云环境</button>
  </view>
  
  <view class="goods-list">
    <block wx:for="{{goodsList}}" wx:key="_id">
      <view class="goods-item">
        <view class="goods-info">
          <view class="goods-name">{{item.name || '未命名组件'}}</view>
          <view class="price-info">
            <text class="price-label">价格:</text> <text class="price-value">¥{{item.price || '0'}}</text>
            <text class="supplier-price" wx:if="{{item.supplierPrice}}">供应商价: ¥{{item.supplierPrice}}</text>
          </view>
          <view class="sku-info" wx:if="{{!item.notLinked}}">
            SKU: {{item.skuId}}
          </view>
          <view class="sku-info not-linked" wx:else>
            尚未关联SKU
          </view>
        </view>
        
        <!-- 非编辑状态显示按钮 -->
        <view class="action-buttons" wx:if="{{editingIndex !== index}}">
          <button class="sku-btn modify" wx:if="{{!item.notLinked}}" bindtap="linkSku" data-index="{{index}}">修改SKU</button>
          <button class="sku-btn link" wx:else bindtap="linkSku" data-index="{{index}}">关联SKU</button>
          <button class="sku-btn supplier" bindtap="editSupplierPrice" data-index="{{index}}">设置供应价</button>
        </view>
        
        <!-- 编辑SKU状态显示输入框 -->
        <view class="edit-area" wx:elif="{{editMode === 'sku'}}">
          <input class="sku-input" value="{{skuInput}}" bindinput="onSkuInput" placeholder="请输入SKU编号" />
          <view class="edit-buttons">
            <button class="edit-btn cancel" bindtap="cancelEdit">取消</button>
            <button class="edit-btn save" bindtap="saveSku">保存</button>
          </view>
        </view>
        
        <!-- 编辑供应商价格状态 -->
        <view class="edit-area" wx:elif="{{editMode === 'supplier'}}">
          <input class="price-input" type="digit" value="{{supplierPriceInput}}" bindinput="onSupplierPriceInput" placeholder="请输入供应商价格" />
          <view class="edit-buttons">
            <button class="edit-btn cancel" bindtap="cancelEdit">取消</button>
            <button class="edit-btn save" bindtap="saveSupplierPrice">保存</button>
          </view>
        </view>
      </view>
    </block>
  </view>
  
  <!-- 添加状态提示 -->
  <view class="status-info" wx:if="{{goodsList.length > 0}}">
    <view>已关联SKU: {{goodsList.filter(item => !item.notLinked).length}} 个</view>
    <view>未关联SKU: {{goodsList.filter(item => item.notLinked).length}} 个</view>
    <view>已设置供应商价: {{goodsList.filter(item => item.supplierPrice).length}} 个</view>
  </view>
  
  <view class="empty-tip" wx:if="{{!goodsList || goodsList.length === 0}}">
    暂无商品数据
  </view>
</view> 