/* pages/recommendation/index.wxss */

/* 主容器 */
.recommendation-container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #1a1a1a;
}

/* 页面头部 */
.header {
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8a8a8a;
}

/* 每个选择区块 */
.section {
  background-color: #222222;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #fff;
}

/* 用途选择样式 */
.purpose-selector {
  display: flex;
  justify-content: space-between;
}

.purpose-option {
  flex: 1;
  text-align: center;
  padding: 30rpx 10rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.purpose-option.active {
  background-color: rgba(255, 140, 0, 0.2);
  color: #ff8c00;
}

.purpose-icon {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 16rpx;
  font-size: 80rpx;
  line-height: 80rpx;
}

.purpose-label {
  font-size: 28rpx;
  color: #fff;
}

/* 图标类样式 */
.icon-game-fill:before {
  content: "🎮";
}

.icon-computer-fill:before {
  content: "🖥️";
}

.icon-briefcase-fill:before {
  content: "💼";
}

.icon-star-fill:before {
  content: "⭐";
}

/* 预算选择样式 */
.budget-selector {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.budget-option {
  width: 18%;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 10rpx;
  background-color: #333333;
  margin-bottom: 20rpx;
  transition: all 0.3s;
}

.budget-option.active {
  background-color: #ff8c00;
  color: white;
}

.budget-label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #fff;
}

.budget-desc {
  font-size: 22rpx;
  color: #8a8a8a;
}

.budget-option.active .budget-desc {
  color: rgba(255, 255, 255, 0.8);
}

/* 自定义预算滑块 */
.custom-budget {
  margin-top: 30rpx;
}

.budget-value {
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #ff8c00;
  margin-bottom: 20rpx;
}

/* 优先级选择样式 */
.priority-selector {
  display: flex;
  justify-content: space-between;
}

.priority-option {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 10rpx;
  background-color: #333333;
  margin: 0 10rpx;
  transition: all 0.3s;
}

.priority-option:first-child {
  margin-left: 0;
}

.priority-option:last-child {
  margin-right: 0;
}

.priority-option.active {
  background-color: #ff8c00;
  color: white;
}

.priority-label {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #fff;
}

.priority-desc {
  font-size: 22rpx;
  color: #8a8a8a;
}

.priority-option.active .priority-desc {
  color: rgba(255, 255, 255, 0.8);
}

/* 提交按钮 */
.action-section {
  margin: 60rpx 0;
}

.recommend-btn {
  background-color: #ff8c00;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  width: 80%;
  margin: 0 auto;
  transition: all 0.3s;
}

.recommend-btn.loading {
  background-color: #ffaa66;
}

.recommend-btn:active {
  opacity: 0.8;
}

/* 底部说明 */
.recommendation-notice {
  text-align: center;
  font-size: 24rpx;
  color: #8a8a8a;
  margin-bottom: 30rpx;
  padding: 0 40rpx;
  line-height: 1.5;
} 