/* pages/recommendation/result.wxss */

/* 主容器 */
.result-container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #1a1a1a;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 140, 0, 0.2);
  border-top: 6rpx solid #ff8c00;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 30rpx;
  color: #8a8a8a;
}

/* 结果头部 */
.result-header {
  margin-bottom: 30rpx;
  text-align: center;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.result-subtitle {
  font-size: 28rpx;
  color: #8a8a8a;
}

/* 配置概览 */
.config-overview {
  background-color: #222222;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
}

.config-price {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.price-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff8c00;
}

/* 性能评分 */
.config-score {
  margin-bottom: 30rpx;
  border-bottom: 1px solid #f0f0f0;
  padding-bottom: 20rpx;
}

.score-item {
  margin-bottom: 20rpx;
}

.score-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.score-bar {
  height: 10rpx;
  background-color: #f0f0f0;
  border-radius: 5rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 5rpx;
}

/* 推荐理由 */
.recommend-reason {
  padding-top: 20rpx;
}

.reason-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.reason-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 组件列表 */
.components-list {
  background-color: #222222;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.components-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  border-bottom: 1px solid #333333;
}

.expand-icon {
  color: #999;
  font-size: 24rpx;
}

.components-content {
  max-height: 800rpx;
  overflow-y: auto;
  transition: max-height 0.3s ease;
}

.components-list.expanded .components-content {
  max-height: 2000rpx;
}

/* 组件项 */
.component-item {
  display: flex;
  align-items: flex-start;
  padding: 30rpx;
  border-bottom: 1px solid #333333;
}

.component-item:last-child {
  border-bottom: none;
}

.component-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  text-align: center;
  line-height: 60rpx;
  font-size: 40rpx;
  color: #666;
}

.component-info {
  flex: 1;
  min-width: 0;
}

.component-name {
  font-size: 26rpx;
  color: #fff;
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.component-specs-summary {
  font-size: 24rpx;
  color: #56A9FA;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  padding: 2rpx 0;
}

.component-brand, .component-model {
  font-size: 22rpx;
  color: #8a8a8a;
  margin-bottom: 4rpx;
}

.component-specs-list {
  display: flex;
  flex-direction: column;
  margin-top: 6rpx;
}

.spec-item {
  font-size: 22rpx;
  color: #8a8a8a;
  margin-bottom: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.component-specs {
  font-size: 22rpx;
  color: #8a8a8a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.component-price {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  white-space: nowrap;
}

.quantity {
  font-size: 22rpx;
  color: #8a8a8a;
  margin-left: 4rpx;
}

/* 图标样式 */
.icon-cpu:before { content: "🔲"; }
.icon-motherboard:before { content: "🔄"; }
.icon-gpu:before { content: "📊"; }
.icon-ram:before { content: "🧠"; }
.icon-storage:before { content: "💾"; }
.icon-cooler:before { content: "❄️"; }
.icon-psu:before { content: "⚡"; }
.icon-case:before { content: "🖥️"; }

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 10rpx;
}

.action-btn:first-child {
  margin-left: 0;
}

.action-btn:last-child {
  margin-right: 0;
}

.btn-primary {
  background-color: #ff8c00;
  color: white;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #666;
}

.btn-outline {
  background-color: white;
  color: #ff8c00;
  border: 1px solid #ff8c00;
}

/* 底部提示 */
.recommendation-tips {
  text-align: center;
  font-size: 24rpx;
  color: #8a8a8a;
  line-height: 1.5;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
} 