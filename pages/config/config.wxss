/* pages/config/config.wxss */

/* 全局容器 */
.container {
  padding: 20rpx;
  background-color: var(--background-color);
  min-height: 100vh;
  position: relative;
  padding-bottom: 120rpx; /* 为底部操作栏留出空间 */
}

/* 头部样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background-color: #1e1e1e;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.page-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #ffffff;
}

.header-buttons {
  display: flex;
  align-items: center;
}

.preview-btn {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #cccccc;
  background-color: rgba(255,255,255,0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.preview-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 已选组件摘要 */
.selected-summary {
  margin-bottom: 20rpx;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 10rpx;
}

.selected-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  background-color: var(--surface-color);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

.chip.selected {
  background-color: rgba(255, 140, 0, 0.15);
  color: var(--primary-color);
  border-color: var(--primary-color);
}

/* 配置主体部分 */
.config-container {
  display: flex;
  background-color: var(--surface-color);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 左侧组件导航 */
.component-nav {
  width: 140rpx;
  background-color: var(--surface-color);
  border-right: 2rpx solid var(--border-color);
  overflow-y: auto;
}

.component-nav-item {
  padding: 25rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border-bottom: 2rpx solid var(--border-color);
}

.component-nav-item.active {
  background-color: rgba(255, 140, 0, 0.15);
}

.component-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: rgba(255, 140, 0, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 22rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.component-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.component-nav-item.active .component-label {
  color: var(--primary-color);
}

.component-status {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: var(--border-color);
}

.component-status.selected {
  background-color: var(--primary-color);
}

/* 右侧筛选和组件列表 */
.component-selection {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  height: 100%;
}

/* 组件清单 */
.component-wrapper {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.component-title {
  padding: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
  display: flex;
  justify-content: space-between;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.selected-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.selected-item-name {
  color: var(--primary-color);
}

/* 筛选区 */
.filter-section {
  padding: 15rpx;
  border-bottom: 2rpx solid var(--border-color);
  background-color: var(--surface-color);
}

/* 组件列表 */
.component-list {
  flex: 1;
  height: 0; /* 重要：确保scroll-view占用剩余空间 */
  min-height: auto; /* 不限制最小高度，自适应内容 */
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 保证列表项在组件列表中正常显示 */
.component-item {
  width: 100%;
  box-sizing: border-box;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  background-color: var(--surface-color);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid var(--border-color);
  padding: 30rpx 30rpx; /* 保持原有内边距 */
  position: relative;
  overflow: visible;
}

.component-item.active {
  border-color: var(--primary-color);
  background-color: rgba(255, 140, 0, 0.05);
}

.component-item-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.component-brand {
  width: 80rpx;
  height: 80rpx;
  margin-right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.component-brand image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.component-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.component-item-body {
  margin-bottom: 40rpx;
}

.component-specs {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx 0;
  width: 100%;
}

.spec-item {
  width: 100%; /* 修改为100%宽度，一行显示一个参数 */
  margin-bottom: 10rpx; /* 减小间距 */
  font-size: 28rpx;
  white-space: normal;
  word-break: break-all;
  display: flex; /* 使用flex布局 */
  align-items: flex-start; /* 顶部对齐 */
}

.spec-label {
  color: var(--text-secondary);
  margin-right: 10rpx;
  min-width: 90rpx; /* 设置最小宽度 */
  white-space: nowrap; /* 标签不换行 */
}

.spec-value {
  color: var(--text-primary);
  flex: 1; /* 占用剩余空间 */
  word-break: break-all; /* 允许在任意字符间断行 */
}

.component-item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.component-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff8c00;
}

.select-btn {
  padding: 10rpx 30rpx;
  background-color: #333;
  color: #fff;
  font-size: 28rpx;
  border-radius: 30rpx;
  text-align: center;
  min-width: 160rpx;
}

.select-btn.active {
  background-color: #f90;
  box-shadow: 0 4rpx 8rpx rgba(255, 140, 0, 0.3);
  position: relative;
}

.quantity-selector {
  display: flex;
  align-items: center;
  background-color: #f90;
  border-radius: 30rpx;
  overflow: hidden;
  color: #fff;
  height: 70rpx;
  box-shadow: 0 4rpx 8rpx rgba(255, 140, 0, 0.4);
  margin-left: auto;
  z-index: 999;
  position: relative;
  min-width: 180rpx;
  justify-content: space-between;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.quantity-btn {
  width: 60rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  transition: all 0.2s;
  position: relative;
  z-index: 1000;
  background-color: rgba(0, 0, 0, 0.2);
}

.quantity-btn:active {
  background-color: rgba(0, 0, 0, 0.4);
}

.quantity-value {
  width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  line-height: 70rpx;
  font-weight: bold;
  position: relative;
  z-index: 1000;
}

.decrease {
  border-right: 1px solid rgba(255, 255, 255, 0.3);
}

.increase {
  border-left: 1px solid rgba(255, 255, 255, 0.3);
}

/* 空列表 */
.empty-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx;
  background-color: var(--background-color);
  display: flex;
  justify-content: space-between;
  border-top: 2rpx solid var(--border-color);
  z-index: 10;
}

.action-btn {
  width: 48%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-primary {
  background-color: var(--primary-color);
  color: #ffffff;
}

.btn-secondary {
  background-color: var(--surface-color);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
}

/* 步骤指示器 */
.steps-container {
  margin-bottom: 30rpx;
  padding: 30rpx 20rpx;
  background-color: var(--surface-color);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.steps-list {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  width: 18%;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: var(--border-color);
  margin-bottom: 10rpx;
}

.step-item.active .step-dot {
  background-color: var(--primary-color);
  transform: scale(1.2);
}

.step-item.completed .step-dot {
  background-color: var(--primary-color);
}

.step-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
}

.step-item.active .step-label {
  color: var(--primary-color);
  font-weight: 500;
}

.step-item.completed .step-label {
  color: var(--primary-color);
}

.step-line {
  flex: 1;
  height: 2rpx;
  background-color: var(--border-color);
  position: relative;
  top: -20rpx;
}

.step-line.active {
  background-color: var(--primary-color);
}

/* 返回按钮 */
.back-btn {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.back-icon {
  margin-right: 8rpx;
}

/* 使用场景选择 */
.section-container {
  margin-bottom: 30rpx;
  background-color: var(--surface-color);
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
  color: var(--text-primary);
}

.purpose-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.purpose-item {
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
  background-color: var(--surface-color);
  border-radius: 8rpx;
}

.purpose-item.active {
  background-color: rgba(255, 140, 0, 0.15);
  border: 2rpx solid var(--primary-color);
}

.purpose-item:active {
  background-color: rgba(255, 140, 0, 0.1);
}

.purpose-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.purpose-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  color: var(--text-primary);
}

.purpose-desc {
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* 品牌筛选标签 */
.filter-tabs {
  background-color: var(--surface-color);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-right: 2rpx solid var(--border-color);
}

.filter-tab:last-child {
  border-right: none;
}

.filter-tab.active {
  background-color: var(--primary-color);
  color: #fff;
}

/* CPU和GPU列表 */
.cpu-list, .gpu-list {
  margin-bottom: 20rpx;
}

.cpu-item, .gpu-item, .no-gpu-option {
  display: flex;
  margin-bottom: 20rpx;
  padding: 20rpx;
  position: relative;
  transition: all 0.3s;
}

.cpu-item.selected, .gpu-item.selected, .no-gpu-option.selected {
  border: 2rpx solid var(--primary-color);
  background-color: rgba(255, 140, 0, 0.05);
}

.cpu-brand-logo, .gpu-brand-logo {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cpu-brand-logo image, .gpu-brand-logo image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.cpu-info, .gpu-info, .no-gpu-info {
  flex: 1;
}

.cpu-name, .gpu-name, .no-gpu-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.cpu-spec, .gpu-spec, .no-gpu-desc {
  margin-bottom: 10rpx;
}

.check-icon {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  color: var(--primary-color);
  font-weight: bold;
  font-size: 32rpx;
}

/* 预算滑块 */
.budget-section {
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.budget-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.budget-value {
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 40rpx;
}

.budget-range {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 组件选择 */
.component-list {
  margin-bottom: 30rpx;
}

.component-card {
  margin-bottom: 20rpx;
  background-color: var(--surface-color);
  border-radius: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.component-header {
  padding: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.component-type {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.component-required {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
  background-color: var(--primary-color);
  color: #fff;
}

.component-optional {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 10rpx;
  background-color: var(--border-color);
  color: var(--text-secondary);
}

.component-item {
  padding: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.component-item:last-child {
  border-bottom: none;
}

.component-item.selected {
  background-color: rgba(255, 140, 0, 0.1);
}

.component-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
  color: var(--text-primary);
}

.component-spec {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.component-price {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: bold;
}

/* 配置结果 */
.config-overview {
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.config-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.config-desc {
  margin-bottom: 16rpx;
}

.config-price {
  font-size: 36rpx;
  font-weight: 600;
}

/* 性能评分卡片 */
.performance-card {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.performance-grid {
  padding: 10rpx 0;
}

.performance-item {
  width: 33.33%;
}

.performance-value {
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.gaming {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4caf50;
}

.value {
  background-color: rgba(33, 150, 243, 0.1);
  color: #2196f3;
}

.thermal {
  background-color: rgba(255, 152, 0, 0.1);
  color: #ff9800;
}

.performance-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 配件列表 */
.components-card {
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.components-list {
  padding: 10rpx 0;
}

.component-item {
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.component-item:last-child {
  border-bottom: none;
}

.component-name {
  font-size: 26rpx;
}

.component-spec {
  margin-top: 6rpx;
}

/* 操作按钮 */
.action-buttons {
  margin: 40rpx 0;
}

.action-buttons .btn {
  width: 48%;
}

/* 修改组件项的选中样式 */
.component-item.active {
  border-color: var(--primary-color);
  background-color: rgba(255, 140, 0, 0.05);
}

/* 筛选区相关样式 */
.filter-row {
  margin-bottom: 20rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.brand-filter {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx;
  transition: max-height 0.3s ease;
  overflow: hidden;
}

.brand-filter.folded {
  max-height: 90rpx;
  overflow: hidden;
}

/* 全部品牌选项样式 - 容器样式 */
.brand-all {
  padding: 10rpx 20rpx;
  margin: 0 10rpx 10rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: rgba(255, 140, 0, 0.1);
  color: #333;
  font-weight: 500;
  width: 100%;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 1px solid rgba(255, 140, 0, 0.2);
}

.brand-all::before {
  content: "🏷️";
  margin-right: 8rpx;
  font-size: 28rpx;
}

.brand-all.active {
  background-color: rgba(255, 140, 0, 0.2);
  color: #ff8c00;
  border-color: #ff8c00;
}

.brand-item {
  padding: 10rpx 20rpx;
  margin: 0 10rpx 10rpx 0;
  border-radius: 30rpx;
  font-size: 26rpx;
  background-color: #333;
  color: #ddd;
  transition: all 0.3s;
  white-space: normal;
  max-width: 200rpx;
  word-break: break-word;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.brand-item.active {
  background-color: #ff8c00;
  color: #fff;
}

.price-filter {
  display: flex;
}

.price-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-right: 2rpx solid var(--border-color);
  background-color: rgba(255, 255, 255, 0.05);
}

.price-item:last-child {
  border-right: none;
}

.price-item.active {
  background-color: var(--primary-color);
  color: #ffffff;
}

.compatibility-notice {
  font-size: 24rpx;
  font-weight: normal;
  color: var(--primary-color);
  margin-left: 10rpx;
}

/* 调试信息样式 */
.debug-info {
  display: none;
}

.btn-hover {
  background-color: rgba(0, 0, 0, 0.2);
  opacity: 0.9;
}

.quantity-tag {
  display: inline-block;
  margin-left: 10rpx;
  font-weight: bold;
  color: #f90;
}

.quantity-controls {
  display: flex;
  justify-content: flex-end;
  padding: 10rpx 0;
  margin-top: 20rpx;
}

.quantity-control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f90;
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(255, 140, 0, 0.4);
}

.number-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 180rpx;
  padding: 0 10rpx;
}

.quantity-label {
  font-size: 24rpx;
  color: #ffffff;
  margin-right: 5rpx;
}

.quantity-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

.quantity-ctrl {
  display: flex;
  align-items: center;
}

.minus, .plus {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border-radius: 50%;
  font-size: 28rpx;
  margin: 0 5rpx;
}

.minus:active, .plus:active {
  background: rgba(255, 255, 255, 0.3);
}

/* Debug信息样式 */
.debug-item-status {
  position: absolute;
  bottom: -30rpx;
  left: 0;
  width: 100%;
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

.debug-area {
  background: #f8f8f8;
  border: 1px solid #ddd;
  padding: 10rpx;
  margin: 10rpx 0;
  font-size: 24rpx;
  color: #666;
}

.debug-tools {
  margin-top: 10rpx;
  display: flex;
  justify-content: center;
}

.debug-tools button {
  font-size: 20rpx;
  margin: 0 10rpx;
}

/* 品牌筛选区样式 */
.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 20rpx;
  margin-bottom: 10rpx;
  cursor: pointer;
}

.fold-icon {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.brand-filter {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx;
  transition: max-height 0.3s ease-in-out;
  overflow: hidden;
  max-height: 600rpx; /* 展开状态的最大高度 */
}

.brand-filter.folded {
  max-height: 90rpx; /* 折叠状态的高度，刚好显示一行 */
  overflow: hidden;
}

.brand-item {
  padding: 10rpx 20rpx;
  margin: 0 10rpx 10rpx 0;
  border-radius: 30rpx;
  font-size: 26rpx;
  background-color: #333;
  color: #ddd;
  transition: all 0.3s;
  white-space: normal;
  max-width: 200rpx;
  word-break: break-word;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.brand-item.active {
  background-color: #ff8c00;
  color: #fff;
}

.brand-more {
  padding: 6rpx 20rpx;
  color: #ff8c00;
  font-size: 24rpx;
  margin: 0 10rpx 10rpx 0;
  border: 1rpx solid #ff8c00;
  border-radius: 30rpx;
  display: inline-block;
}

/* 兼容性过滤样式 */
.compatibility-filter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  padding: 8rpx 0;
}

.compatibility-switch {
  display: flex;
  align-items: center;
}

.compatibility-switch .switch-label {
  font-size: 26rpx;
  color: #cccccc;
  margin-left: 12rpx;
}

.filter-stats {
  font-size: 24rpx;
  color: #ff8c00;
  margin: 0 20rpx 16rpx;
  padding-bottom: 10rpx;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

/* 组件导入区域样式 */
.component-import-area {
  background-color: rgba(255, 140, 0, 0.1);
  border-radius: 8rpx;
  margin: 10rpx 20rpx;
  padding: 15rpx;
}

.import-tip {
  font-size: 26rpx;
  color: #ff8c00;
  margin-bottom: 10rpx;
}

.import-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.import-btns button {
  margin: 0;
  font-size: 24rpx;
  background-color: #ff8c00;
}

.import-btns button:active {
  background-color: #e67e00;
}

.cloud-deploy-tip {
  font-size: 24rpx;
  color: #ff3333;
  margin-bottom: 15rpx;
  padding: 10rpx;
  background: rgba(255, 51, 51, 0.1);
  border-radius: 6rpx;
  text-align: center;
  font-weight: bold;
}

/* CPU和散热器兼容性提示样式 */
.compatibility-tips {
  margin: 20rpx 0;
  padding: 20rpx;
  background-color: rgba(255, 140, 0, 0.1);
  border-radius: 12rpx;
  border-left: 6rpx solid #ff8c00;
}

.tip-content {
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #e0e0e0;
}

.tip-detail {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #b0b0b0;
}

.tip-note {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #ff8c00;
}

/* 价格更新时间 */
.price-update-time {
  font-size: 22rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 新增刷新按钮样式 */
.refresh-btn {
  display: flex;
  align-items: center;
  background-color: #4CAF50;
  color: white;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 20rpx;
  font-size: 26rpx;
}

.refresh-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
} 