<!-- 获取adminApi的HTTP触发器URL页面 -->
<view class="container">
  <view class="title">获取adminApi的HTTP触发器URL</view>
  <button type="primary" bindtap="getApiUrl">获取URL</button>
  
  <view class="result-container" wx:if="{{apiUrl}}">
    <view class="result-title">HTTP触发器URL：</view>
    <view class="result-url">{{apiUrl}}</view>
    <button size="mini" type="default" bindtap="copyUrl">复制URL</button>
  </view>
  
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="error" wx:if="{{error}}">{{error}}</view>
</view> 