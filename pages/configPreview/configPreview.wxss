/* pages/configPreview/configPreview.wxss */

.container {
  background-color: #1a1a1a;
  color: #ffffff;
  min-height: 100vh;
  padding-bottom: 110rpx; /* 为底部按钮留出空间 */
}

/* 标题栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid #333;
  background-color: #ff8c00;
  padding: 20rpx;
  height: 60rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 加载提示 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
}

.loading {
  font-size: 28rpx;
  color: #cccccc;
}

/* 配置内容 */
.config-content {
  padding: 0;
}

/* 配件清单标题 */
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff8c00;
  padding: 20rpx;
  border-bottom: 1px solid #333;
}

/* 组件列表 */
.components-list {
  margin-bottom: 30rpx;
}

/* 组件项 */
.component-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1px solid #333;
}

/* 交替行背景 */
.component-item.even-row {
  background-color: #252525;
}

/* 组件图标 */
.component-icon {
  width: 50rpx;
  height: 50rpx;
  background-color: #333;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 6rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 24rpx;
}

/* 组件主要信息 */
.component-main {
  flex: 1;
  overflow: hidden;
}

/* 组件信息行 */
.component-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.component-type {
  font-size: 26rpx;
  font-weight: bold;
  color: #ff8c00;
  margin-right: 10rpx;
  width: 70rpx;
  flex-shrink: 0;
}

.component-name {
  font-size: 26rpx;
  color: #ffffff;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 10rpx;
}

.component-price {
  font-size: 26rpx;
  color: #ff8c00;
  font-weight: bold;
  width: 100rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 组件规格 */
.component-specs {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  font-size: 22rpx;
  color: #aaaaaa;
  margin-left: 70rpx;
}

/* 品牌和型号行 */
.component-brand-model {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-left: 70rpx;
  margin-bottom: 8rpx;
}

.brand-item, .model-item, .quantity-item {
  font-size: 22rpx;
  color: #bbbbbb;
  background-color: rgba(255, 255, 255, 0.07);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

.brand-item {
  color: #ff9d4d;
}

.spec-item {
  background-color: rgba(255, 255, 255, 0.05);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 15rpx;
  background-color: #252525;
  border-top: 1px solid #333;
}

.btn {
  border-radius: 6rpx;
  font-size: 28rpx;
  padding: 0;
  line-height: 80rpx;
  height: 80rpx;
}

.btn-back {
  flex: 1;
  background-color: #333;
  color: #ffffff;
  margin-right: 10rpx;
}

.btn-share {
  flex: 1;
  background-color: #ff8c00;
  color: #ffffff;
  margin-right: 10rpx;
}

.btn-save {
  flex: 1.2;
  background-color: #ff8c00;
  color: #ffffff;
} 