/* pages/components/cpu.wxss */
.container {
  padding: 0 30rpx;
  background-color: #f9f9f9;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 错误提示 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.error-text {
  margin: 30rpx 0;
  color: #e74c3c;
}

/* CPU列表 */
.cpu-list {
  height: calc(100vh - 120rpx);
}

.cpu-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.cpu-info {
  flex: 1;
}

.cpu-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.cpu-brand {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.cpu-specs {
  display: flex;
  flex-wrap: wrap;
}

.cpu-specs text {
  font-size: 24rpx;
  color: #888;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
  background-color: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.cpu-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6700;
  display: flex;
  align-items: center;
  margin-left: 20rpx;
} 