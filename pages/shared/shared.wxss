  color: #999;
  font-weight: normal;
  margin-top: 4rpx;
}

/* 底部区域 */
.footer {
  margin-top: 40rpx;
}

.footer-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.footer-info {
  display: flex;
