<!--pages/hardware/hardware.wxml-->
<view class="guide-container">
  <swiper class="swiper" indicator-dots="{{false}}" autoplay="{{false}}" current="{{currentSlide-1}}">
    <swiper-item>
      <view class="slide">
        <view class="logo animate-float">
          <view class="logo-circle">
            <view class="logo-text">PC</view>
          </view>
        </view>
        <text class="slide-title">欢迎使用台式电脑配置助手</text>
        <text class="slide-desc">一款专业的电脑硬件配置工具，帮助您轻松组装理想中的电脑</text>
      </view>
    </swiper-item>
    
    <swiper-item>
      <view class="slide">
        <image src="data:image/svg+xml;base64," class="slide-img" mode="aspectFit"></image>
        <text class="slide-title">专业配置推荐</text>
        <text class="slide-desc">根据您的预算和需求，智能推荐最适合的电脑配置方案</text>
      </view>
    </swiper-item>
    
    <swiper-item>
      <view class="slide">
        <image src="data:image/svg+xml;base64," class="slide-img" mode="aspectFit"></image>
        <text class="slide-title">性能价格对比</text>
        <text class="slide-desc">轻松对比不同配置的性能差异和性价比，做出明智选择</text>
      </view>
    </swiper-item>
    
    <swiper-item>
      <view class="slide">
        <image src="data:image/svg+xml;base64," class="slide-img" mode="aspectFit"></image>
        <text class="slide-title">保存分享配置</text>
        <text class="slide-desc">保存您喜欢的配置方案，随时查看和分享给朋友</text>
      </view>
    </swiper-item>
  </swiper>
  
  <view class="indicators">
    <block wx:for="{{[1, 2, 3, 4]}}" wx:key="*this">
      <view class="indicator {{currentSlide == item ? 'active' : ''}}" bindtap="goToSlide" data-slide="{{item}}"></view>
    </block>
  </view>
  
  <view class="buttons">
    <button class="btn btn-skip" bindtap="skipGuide">跳过</button>
    <button class="btn btn-primary" bindtap="nextSlide">{{currentSlide == 4 ? '立即体验' : '下一步'}}</button>
  </view>
</view> 