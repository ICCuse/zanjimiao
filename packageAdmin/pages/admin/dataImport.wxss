.container {
  padding: 20rpx;
}

.header {
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.option-area {
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
}

.option-item text {
  margin-left: 10rpx;
  font-size: 28rpx;
}

.status-area {
  background-color: #f0f9eb;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.status-text {
  color: #67c23a;
  font-size: 28rpx;
  word-break: break-all;
}

.import-area {
  margin-top: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.json-textarea {
  width: 100%;
  height: 400rpx;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  background-color: #fff;
}

.import-btn {
  margin: 20rpx 0;
  background-color: #1989fa;
  color: #fff;
}

.import-tips {
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  display: block;
  line-height: 1.5;
} 