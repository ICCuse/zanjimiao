/**app.wxss**/
page {
  --primary-color: #ff8c00;
  --primary-light: #ffaf4d;
  --primary-dark: #cc7000;
  --background-color: #1a1a1a;
  --surface-color: #292929;
  --on-surface-color: #ffffff;
  --text-primary: #ffffff;
  --text-secondary: #cccccc;
  --text-hint: #999999;
  --border-color: #333333;
  --success-color: #ff8c00;
  --error-color: #f44336;

  background-color: var(--background-color);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 14px;
  line-height: 1.5;
}

/* 清除微信小程序默认样式 */
view, text, navigator, button, input {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

/* 全局容器 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: var(--surface-color);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

/* 按钮样式 */
.btn {
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0;
}

.btn-primary {
  background-color: var(--primary-color);
  color: #fff;
}

.btn-outline {
  background-color: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-text {
  background-color: transparent;
  color: var(--primary-color);
  padding: 10rpx 20rpx;
}

/* 文本样式 */
.text-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.text-subtitle {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.text-body {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.text-caption {
  font-size: 24rpx;
  color: var(--text-hint);
}

.text-price {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* Flex 布局助手 */
.flex {
  display: flex;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.align-center {
  align-items: center;
}

.align-start {
  align-items: flex-start;
}

.align-end {
  align-items: flex-end;
}

/* 间距辅助类 */
.m-10 { margin: 10rpx; }
.m-20 { margin: 20rpx; }
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

.p-10 { padding: 10rpx; }
.p-20 { padding: 20rpx; }
.pt-10 { padding-top: 10rpx; }
.pt-20 { padding-top: 20rpx; }
.pb-10 { padding-bottom: 10rpx; }
.pb-20 { padding-bottom: 20rpx; }
.pl-10 { padding-left: 10rpx; }
.pl-20 { padding-left: 20rpx; }
.pr-10 { padding-right: 10rpx; }
.pr-20 { padding-right: 20rpx; }

/* 边框样式 */
.border-top {
  border-top: 2rpx solid var(--border-color);
}

.border-bottom {
  border-bottom: 2rpx solid var(--border-color);
}

/* 阴影 */
.shadow {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.shadow-lg {
  box-shadow: 0 10rpx 15rpx rgba(0, 0, 0, 0.3);
}

/* 圆角 */
.rounded {
  border-radius: 8rpx;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-full {
  border-radius: 9999rpx;
}

/* 图片样式 */
.img-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.img-contain {
  width: 100%;
  height: 100%;
  object-fit: contain;
} 